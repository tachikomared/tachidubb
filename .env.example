# Copy to .env and fill in your own values

# Hugging Face token (only needed for speaker diarization)
# Get one at: https://huggingface.co/settings/tokens
# Then accept terms: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=

# VoxCPM model (default is fine)
VOXCPM_MODEL=openbmb/VoxCPM2
VOXCPM_CFG=2.0
VOXCPM_STEPS=10

# Ollama (default is fine)
OLLAMA_URL=http://localhost:11434

# UI auto-open on start (1=on, 0=off)
TACHIDUBB_OPEN_BROWSER=1
